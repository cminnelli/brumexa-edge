# ── LiveKit Server ─────────────────────────────────────────────────
# URL de tu servidor LiveKit (wss:// para producción, ws:// para local)
LIVEKIT_URL=wss://your-livekit-server.livekit.cloud

# Credenciales de la API (generadas en el dashboard de LiveKit)
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Nombre de la sala por defecto
LIVEKIT_ROOM_NAME=voice-room

# ── Servidor Express ────────────────────────────────────────────────
PORT=3000
